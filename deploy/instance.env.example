# Per-instance env file for surfagent@<id>.service.
#
# Copy to ~/.config/surfagent/instance-<id>.env and edit ports + chrome dir
# so each fleet instance binds a unique CDP_PORT + API_PORT and writes its
# Chrome profile to a unique directory.
#
# Reference fleet allocation (a-e, shipped 2026-05-19):
#   instance-a: CDP_PORT=9222  API_PORT=3456
#   instance-b: CDP_PORT=9300  API_PORT=3500
#   instance-c: CDP_PORT=9301  API_PORT=3501
#   instance-d: CDP_PORT=9302  API_PORT=3502
#   instance-e: CDP_PORT=9303  API_PORT=3503

CDP_PORT=9222
API_PORT=3456
CHROME_USER_DATA_DIR=/tmp/surfagent-chrome-a

# DISPLAY is set to :0 in surfagent@.service (matches Zorin OS 18.1 GDM
# default). Uncomment ONLY if your host's X session lives on a different
# display number (e.g. older Ubuntu defaults to :1).
# DISPLAY=:1
